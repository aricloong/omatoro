---
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
  activePage?: string;
}

const {
  title,
  description = 'OmaToro — 旬味 · 配对 · 匠心社区 | 探索寿司文化的终极目的地',
  activePage = ''
} = Astro.props;

const navLinks = [
  { href: '/',        label: '首页',   key: 'home',  i18n: 'nav.home'  },
  { href: '/wiki',    label: '百科',   key: 'wiki',  i18n: 'nav.wiki'  },
  { href: '/tools',   label: '工具箱', key: 'tools', i18n: 'nav.tools' },
  { href: '/about',   label: '关于',   key: 'about', i18n: 'nav.about' },
];
---
<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>{title} | OmaToro</title>
  <meta name="description" content={description}/>
  <meta property="og:title" content={`${title} | OmaToro`}/>
  <meta property="og:description" content={description}/>
  <meta property="og:type" content="website"/>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@400;500;600;700&family=Noto+Serif+SC:wght@600;700&display=swap" rel="stylesheet"/>
  <script is:inline>
    (function() {
      const saved = localStorage.getItem('omatoro-theme');
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      if (saved === 'dark' || (!saved && prefersDark)) {
        document.documentElement.setAttribute('data-theme', 'dark');
      }
    })();
  </script>
</head>
<body>
  <header class="nav-wrap" id="navbar">
    <div class="container">
      <div class="nav-inner">
        <a href="/" class="nav-logo" aria-label="OmaToro 首页">
          <svg width="36" height="36" viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <circle cx="18" cy="18" r="16" stroke="#C41E3A" stroke-width="2.5" stroke-linecap="round"
              stroke-dasharray="88 12" stroke-dashoffset="6"
              style="transform-origin:center;transform:rotate(-15deg)"/>
            <ellipse cx="17" cy="18" rx="8" ry="5.5" fill="#C41E3A" opacity="0.92"/>
            <path d="M25 18 C27 14 31 13 31 18 C31 23 27 22 25 18Z" fill="#C41E3A" opacity="0.75"/>
            <circle cx="12.5" cy="17" r="1.5" fill="#fff"/>
            <circle cx="12.5" cy="17" r="0.7" fill="#8B0000"/>
            <path d="M15 16 Q18 15.5 22 16.5" stroke="#fff" stroke-width="0.8" opacity="0.6" stroke-linecap="round"/>
            <path d="M14 18.5 Q17 18 21 18.8" stroke="#fff" stroke-width="0.6" opacity="0.4" stroke-linecap="round"/>
          </svg>
          <div class="nav-logo-text">
            <span class="logo-oma">Oma</span><span class="logo-toro">Toro</span>
          </div>
          <span class="nav-beta" data-i18n="nav.beta">Beta</span>
        </a>
        <nav class="nav-links" aria-label="主导航">
          {navLinks.map(link => (
            <a
              href={link.href}
              class={`nav-link ${activePage === link.key ? 'active' : ''}`}
              data-i18n={link.i18n}
              aria-current={activePage === link.key ? 'page' : undefined}
            >
              {link.label}
            </a>
          ))}
          <div class="nav-actions">
            <button id="themeToggle" class="nav-action-btn" aria-label="切换主题" data-i18n-title="themeToggle">
              <svg id="themeIcon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="5"/>
                <line x1="12" y1="1" x2="12" y2="3"/>
                <line x1="12" y1="21" x2="12" y2="23"/>
                <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
                <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
                <line x1="1" y1="12" x2="3" y2="12"/>
                <line x1="21" y1="12" x2="23" y2="12"/>
                <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
                <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
              </svg>
            </button>
            <div class="lang">
              <button type="button" id="langToggle" class="nav-action-btn lang-toggle" aria-label="选择语言" aria-haspopup="true">
                <span aria-hidden="true">🌐</span> <span id="langCurrent">中文</span>
              </button>
              <div id="langDropdown" class="lang-dropdown" role="menu">
                <a href="#" class="lang-option" data-lang="zh-CN" role="menuitem">🇨🇳 中文</a>
                <a href="#" class="lang-option" data-lang="ja" role="menuitem">🇯🇵 日本語</a>
                <a href="#" class="lang-option" data-lang="en" role="menuitem">🇺🇸 English</a>
                <a href="#" class="lang-option" data-lang="fr" role="menuitem">🇫🇷 Français</a>
                <a href="#" class="lang-option" data-lang="es" role="menuitem">🇪🇸 Español</a>
                <a href="#" class="lang-option" data-lang="ar" role="menuitem">🇸🇦 العربية</a>
                <a href="#" class="lang-option" data-lang="ru" role="menuitem">🇷🇺 Русский</a>
              </div>
            </div>
          </div>
        </nav>
        <button class="nav-mobile-btn" id="mobileMenuBtn" aria-label="打开菜单" aria-expanded="false">
          <span class="ham-line"></span>
          <span class="ham-line"></span>
          <span class="ham-line"></span>
        </button>
      </div>
    </div>
    <div id="mobileMenu" class="mobile-menu" aria-hidden="true">
      <div class="container">
        {navLinks.map(link => (
          <a href={link.href} class={`mobile-nav-link ${activePage === link.key ? 'active' : ''}`} data-i18n={link.i18n}>
            {link.label}
          </a>
        ))}
        <a href="/wiki#submit" class="btn btn-primary" style="margin-top:10px;width:100%;justify-content:center" data-i18n="nav.submit">✏️ 投稿新鱼种</a>
      </div>
    </div>
  </header>

  <main><slot/></main>

  <footer class="footer">
    <div class="container">
      <div class="footer-grid">
        <div class="footer-brand">
          <div class="footer-logo">
            <svg width="28" height="28" viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="18" cy="18" r="16" stroke="#C41E3A" stroke-width="2.5" stroke-linecap="round" stroke-dasharray="88 12" stroke-dashoffset="6" style="transform-origin:center;transform:rotate(-15deg)"/>
              <ellipse cx="17" cy="18" rx="8" ry="5.5" fill="#C41E3A" opacity="0.92"/>
              <path d="M25 18 C27 14 31 13 31 18 C31 23 27 22 25 18Z" fill="#C41E3A" opacity="0.75"/>
              <circle cx="12.5" cy="17" r="1.5" fill="#fff"/>
              <circle cx="12.5" cy="17" r="0.7" fill="#8B0000"/>
            </svg>
            <span style="font-size:18px;font-weight:800;color:#fff">
              <span style="color:#e0604a">Oma</span><span style="color:#DAA520">Toro</span>
            </span>
          </div>
          <p class="footer-desc" data-i18n="footer.brand">旬味 · 配对 · 匠心社区<br/><em style="color:rgba(255,255,255,.35);font-style:italic;font-size:12px">Savor the Season. Explore the Craft.</em></p>
          <p class="footer-copy">© {new Date().getFullYear()} OmaToro · omatoro.com</p>
        </div>
        <div class="footer-col">
          <h4 class="footer-heading" data-i18n="footer.explore">探索</h4>
          <nav class="footer-nav">
            {navLinks.map(l => (<a href={l.href} class="footer-link" data-i18n={l.i18n}>{l.label}</a>))}
          </nav>
        </div>
        <div class="footer-col">
          <h4 class="footer-heading" data-i18n="footer.tools">工具</h4>
          <nav class="footer-nav">
            <a href="/tools#pairing"  class="footer-link" data-i18n="tools.pairing">🍶 清酒配对</a>
            <a href="/tools#calendar" class="footer-link" data-i18n="tools.calendar">📅 旬味日历</a>
            <a href="/tools#calories" class="footer-link" data-i18n="tools.calories">🔥 热量计算</a>
            <a href="/tools#quiz"     class="footer-link" data-i18n="tools.quiz">🎯 知识问答</a>
          </nav>
        </div>
        <div class="footer-col">
          <h4 class="footer-heading" data-i18n="footer.contact">联系</h4>
          <a href="mailto:hello@omatoro.com" class="footer-email">hello@omatoro.com</a>
          <p class="footer-contact-note" data-i18n="footer.welcomeNote">欢迎投稿 · 意见反馈<br/>专业合作洽谈</p>
        </div>
      </div>
      <div class="footer-bottom">
        <p data-i18n="footer.note">数据仅供参考，实际食材以当地市场为准</p>
        <p data-i18n="footer.made">Made with 🍣 by OmaToro Community</p>
      </div>
    </div>
  </footer>

  <script>
    const nav = document.getElementById('navbar');
    if (nav) {
      window.addEventListener('scroll', () => {
        nav.classList.toggle('scrolled', window.scrollY > 24);
      }, { passive: true });
    }
    const btn  = document.getElementById('mobileMenuBtn');
    const menu = document.getElementById('mobileMenu');
    if (btn && menu) {
      btn.addEventListener('click', () => {
        const open = menu.classList.toggle('open');
        btn.setAttribute('aria-expanded', String(open));
        menu.setAttribute('aria-hidden',  String(!open));
      });
    }
    window.addEventListener('resize', () => {
      if (window.innerWidth > 640 && menu) {
        menu.classList.remove('open');
        btn?.setAttribute('aria-expanded', 'false');
      }
    });

    (function() {
      const html = document.documentElement;
      function getIsDark() {
        return html.getAttribute('data-theme') === 'dark';
      }
      function updateThemeIcon(isDark) {
        const icon = document.getElementById('themeIcon');
        if (!icon) return;
        if (isDark) {
          icon.innerHTML = '<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>';
        } else {
          icon.innerHTML = '<circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>';
        }
      }
      updateThemeIcon(getIsDark());

      const toggle = document.getElementById('themeToggle');
      if (toggle) {
        toggle.addEventListener('click', () => {
          const isDark = getIsDark();
          const newTheme = isDark ? 'light' : 'dark';
          html.setAttribute('data-theme', newTheme);
          localStorage.setItem('omatoro-theme', newTheme);
          updateThemeIcon(!isDark);
        });
      }
    })();

    (function() {
      const I18N_STORAGE_KEY = 'omatoro-lang';
      const DEFAULT_LANG = 'zh-CN';
      const SUPPORTED_LANGS = ['zh-CN', 'ja', 'en', 'fr', 'es', 'ar', 'ru'];
      const RTL_LANGS = ['ar'];
      const LANG_NAMES = {
        'zh-CN': '中文',
        'ja': '日本語',
        'en': 'English',
        'fr': 'Français',
        'es': 'Español',
        'ar': 'العربية',
        'ru': 'Русский'
      };

      let currentLang = DEFAULT_LANG;
      let currentTranslations = {};

      function applyDirection(lang) {
        document.documentElement.dir = RTL_LANGS.includes(lang) ? 'rtl' : 'ltr';
        document.documentElement.lang = lang;
      }

      function applyTranslations(translations) {
        document.querySelectorAll('[data-i18n]').forEach(el => {
          const key = el.dataset.i18n;
          if (!el.dataset.i18nOriginal) {
            el.dataset.i18nOriginal = el.innerHTML;
          }
          if (translations[key]) {
            el.innerHTML = translations[key];
          }
        });
        document.querySelectorAll('[data-i18n-title]').forEach(el => {
          const key = el.dataset.i18nTitle;
          if (!el.dataset.i18nTitleOriginal) {
            el.dataset.i18nTitleOriginal = el.getAttribute('aria-label') || '';
          }
          if (translations[key]) {
            el.setAttribute('aria-label', translations[key]);
            el.setAttribute('title', translations[key]);
          }
        });
        document.querySelectorAll('[data-i18n-placeholder]').forEach(el => {
          const key = el.dataset.i18nPlaceholder;
          if (!el.dataset.i18nPlaceholderOriginal) {
            el.dataset.i18nPlaceholderOriginal = el.getAttribute('placeholder') || '';
          }
          if (translations[key]) {
            el.setAttribute('placeholder', translations[key]);
          }
        });
      }

      function resetTranslations() {
        document.querySelectorAll('[data-i18n]').forEach(el => {
          if (el.dataset.i18nOriginal) {
            el.innerHTML = el.dataset.i18nOriginal;
          }
        });
        document.querySelectorAll('[data-i18n-title]').forEach(el => {
          if (el.dataset.i18nTitleOriginal) {
            el.setAttribute('aria-label', el.dataset.i18nTitleOriginal);
            el.setAttribute('title', el.dataset.i18nTitleOriginal);
          }
        });
        document.querySelectorAll('[data-i18n-placeholder]').forEach(el => {
          if (el.dataset.i18nPlaceholderOriginal) {
            el.setAttribute('placeholder', el.dataset.i18nPlaceholderOriginal);
          }
        });
      }

      function updateLangSelector(lang) {
        const current = document.getElementById('langCurrent');
        if (current && LANG_NAMES[lang]) {
          current.textContent = LANG_NAMES[lang];
        }
        document.querySelectorAll('.lang-option').forEach(opt => {
          opt.classList.toggle('active', opt.dataset.lang === lang);
        });
      }

      async function loadLanguage(lang, persist = true) {
        if (!SUPPORTED_LANGS.includes(lang)) return;
        applyDirection(lang);

        if (lang === DEFAULT_LANG) {
          resetTranslations();
          currentLang = DEFAULT_LANG;
          currentTranslations = {};
        } else {
          try {
            const res = await fetch(`/lang/${lang}.json`);
            if (!res.ok) throw new Error(`HTTP ${res.status}`);
            currentTranslations = await res.json();
            applyTranslations(currentTranslations);
            currentLang = lang;
          } catch (err) {
            console.warn('[i18n] Failed to load', lang, ':', err);
            return;
          }
        }

        if (persist) {
          localStorage.setItem(I18N_STORAGE_KEY, lang);
        }
        updateLangSelector(lang);
      }

      function detectLang() {
        const prefs = navigator.languages && navigator.languages.length
          ? navigator.languages
          : [navigator.language || DEFAULT_LANG];
        for (const pref of prefs) {
          if (!pref) continue;
          const lc = pref.toLowerCase();
          let hit = SUPPORTED_LANGS.find(s => s.toLowerCase() === lc);
          if (hit) return hit;
          const base = lc.split('-')[0];
          hit = SUPPORTED_LANGS.find(s => s.toLowerCase() === base);
          if (hit) return hit;
          hit = SUPPORTED_LANGS.find(s => s.split('-')[0].toLowerCase() === base);
          if (hit) return hit;
        }
        return DEFAULT_LANG;
      }

      function initI18n() {
        const saved = localStorage.getItem(I18N_STORAGE_KEY);
        if (saved && SUPPORTED_LANGS.includes(saved)) {
          loadLanguage(saved);
        } else {
          const detected = detectLang();
          if (detected !== DEFAULT_LANG) {
            loadLanguage(detected, false);
          } else {
            updateLangSelector(DEFAULT_LANG);
          }
        }

        document.querySelectorAll('.lang-option').forEach(opt => {
          opt.addEventListener('click', e => {
            e.preventDefault();
            const lang = opt.dataset.lang;
            if (lang && SUPPORTED_LANGS.includes(lang)) {
              loadLanguage(lang, true);
              const dropdown = document.getElementById('langDropdown');
              if (dropdown) dropdown.classList.remove('open');
            }
          });
        });

        const langBtn = document.getElementById('langToggle');
        if (langBtn) {
          langBtn.addEventListener('click', e => {
            e.stopPropagation();
            const dropdown = document.getElementById('langDropdown');
            if (dropdown) dropdown.classList.toggle('open');
          });
        }

        document.addEventListener('click', () => {
          const dropdown = document.getElementById('langDropdown');
          if (dropdown) dropdown.classList.remove('open');
        });
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initI18n);
      } else {
        initI18n();
      }
    })();
  </script>
</body>
</html>
